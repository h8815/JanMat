# =============================================================================
# JanMat Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database settings
DB_NAME=janmat_db
DB_USER=janmat_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_2024
DB_HOST=localhost
DB_PORT=5432

# =============================================================================
# DJANGO CONFIGURATION
# =============================================================================
# Django secret key - MUST be changed in production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY_2024

# Debug mode - ALWAYS False in production
DEBUG=False

# Allowed hosts - domains that can access the backend
ALLOWED_HOSTS=localhost,127.0.0.1,backend,janmat.local

# CSRF Trusted Origins - Required for Nginx/Production
# Must include http:// or https:// prefix
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://janmat.local

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Frontend URLs that can access the backend API
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:3000,http://127.0.0.1:80,http://janmat.local:3000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT token lifetimes (in minutes for access, days for refresh)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# =============================================================================
# AADHAAR API CONFIGURATION (Sandbox.co.in)
# =============================================================================
# Real Aadhaar verification API settings
# Get from: https://sandbox.co.in/
SANDBOX_AUTHORIZATION=CHANGE_ME_SANDBOX_AUTH_TOKEN
SANDBOX_API_KEY=CHANGE_ME_SANDBOX_API_KEY

# =============================================================================
# OTP CONFIGURATION
# =============================================================================
# OTP expiry time in minutes
OTP_EXPIRY_MINUTES=5

# Maximum OTP attempts before blocking
MAX_OTP_ATTEMPTS=3

# =============================================================================
# BIOMETRIC CONFIGURATION
# =============================================================================
# Biometric hashing algorithm (SHA256, SHA512)
BIOMETRIC_HASH_ALGORITHM=SHA256

# Salt for biometric hashing - MUST be unique per deployment
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BIOMETRIC_SALT=CHANGE_ME_BIOMETRIC_SALT_2024

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=/app/logs/janmat.log

# =============================================================================
# DOCKER PORTS CONFIGURATION
# =============================================================================
# Port mappings for Docker containers
FRONTEND_PORT=80
BACKEND_PORT=8000

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# =============================================================================
# MONITORING CONFIGURATION (Optional)
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# BACKUP CONFIGURATION (Optional)
# =============================================================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30