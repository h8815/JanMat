# JanMat Backend Configuration
# Copy this file to .env and update with your values

# Database Configuration
DB_NAME=janmat_db
DB_USER=janmat_user
DB_PASSWORD=janmat_secure_pass_2024
DB_HOST=localhost
DB_PORT=5432

# Django Configuration
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Security Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Aadhaar API Configuration (Mock for development)
AADHAAR_API_URL=https://api.aadhaar.gov.in/v1
AADHAAR_API_KEY=your-aadhaar-api-key

# OTP Configuration
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=3

# Biometric Configuration
BIOMETRIC_HASH_ALGORITHM=SHA256
BIOMETRIC_SALT=your-biometric-salt-here

# Logging
LOG_LEVEL=INFO